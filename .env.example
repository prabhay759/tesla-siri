# ══════════════════════════════════════════════════════════════════════════════
#  Tesla Siri Server — environment template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env — it contains secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ── Tesla OAuth app credentials ───────────────────────────────────────────────
# Create your app at https://developer.tesla.com
TESLA_CLIENT_ID=your-client-id-here
TESLA_CLIENT_SECRET=ta-secret.your-secret-here

# ── Your vehicle ──────────────────────────────────────────────────────────────
# Find VIN: Tesla touchscreen → Controls → Software → Additional Vehicle Info
TESLA_VIN=YOUR_VIN_HERE

# ── Tokens (auto-managed — do not set manually) ───────────────────────────────
# Run:  node get-tesla-token.mjs   →   node exchange-code.mjs <code>
# The token manager refreshes these automatically every 6 hours.
TESLA_ACCESS_TOKEN=
TESLA_REFRESH_TOKEN=
TESLA_TOKEN_EXPIRES_AT=

# ── Addresses (used in voice commands: "go home", "drive to work") ────────────
HOME_ADDRESS=Your Home Address, City, Country
WORK_ADDRESS=Your Work Address, City, Country

# ── Server ports ──────────────────────────────────────────────────────────────
MCP_MODE=stdio
MCP_PORT=3001
PORT=3000

# ── Siri endpoint security (optional but recommended) ─────────────────────────
# Set any random string here, then add ?secret=<value> to your Siri Shortcut URL
SIRI_SECRET=

# ── Gemini AI (free key — powers natural language commands) ───────────────────
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Contacts for automatic messaging ─────────────────────────────────────────
# Add one line per contact. Name must match what you say in voice commands.
# Use phone number (+41791234567) or iMessage name/email for iOS Send Message.
# Example: CONTACT_MOM=+41791234567
CONTACT_USER=John

# ── Tesla Fleet API / ngrok ───────────────────────────────────────────────────
TESLA_PUBLIC_KEY_FILE=tesla-public.pem
TESLA_NGROK_DOMAIN=your-ngrok-domain.ngrok-free.dev
